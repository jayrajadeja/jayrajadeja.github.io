# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# superpowers brainstorming artifacts
.superpowers/

# design reference files
/*.html

# typescript
*.tsbuildinfo
next-env.d.ts

# graphify — commit the queryable graph (graph.json), report, viz, manifest;
# ignore local-only intermediates / caches.
graphify-out/cache/
graphify-out/cost.json
graphify-out/.graphify_analysis.json
graphify-out/.graphify_labels.json
